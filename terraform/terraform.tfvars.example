# ─── Hetzner Cloud ───────────────────────────────────────────────────
hcloud_token = "your-hetzner-api-token-here"

# ─── Cluster ─────────────────────────────────────────────────────────
cluster_name = "swarm"
domain       = "example.com"

# ─── SSH ─────────────────────────────────────────────────────────────
ssh_public_key_path  = "~/.ssh/id_ed25519.pub"
ssh_private_key_path = "~/.ssh/id_ed25519"

# ─── Network ─────────────────────────────────────────────────────────
network_zone   = "eu-central"
private_subnet = "10.0.0.0/24"
ip_offset      = 10  # İlk node 10.0.0.10 alır

# ─── Manager Nodes ───────────────────────────────────────────────────
# İlk grubun ilk replica'sı Swarm leader olur.
# HA için replicas = 3 (veya 5) yapın.
managers = {
  infra = {
    server_type = "cx22"
    location    = "fsn1"
    replicas    = 1
    labels      = { "role" = "infra" }
  }
  # HA örneği — farklı bölgede 2 manager daha:
  # infra-nbg = {
  #   server_type = "cx22"
  #   location    = "nbg1"
  #   replicas    = 2
  #   labels      = { "role" = "infra", "zone" = "nbg" }
  # }
}

# ─── Worker Nodes ────────────────────────────────────────────────────
# Yeni worker = yeni block + terraform apply
# replicas ile aynı tipten birden fazla node oluşturulur
workers = {
  data = {
    server_type = "cpx31"
    location    = "fsn1"
    replicas    = 1
    labels      = { "role" = "data" }
  }
  apps = {
    server_type = "cx32"
    location    = "fsn1"
    replicas    = 1
    labels      = { "role" = "apps" }
  }
  tools = {
    server_type = "cx32"
    location    = "fsn1"
    replicas    = 1
    labels      = { "role" = "tools" }
  }
  # ─── Örnek: 2 ML worker ─────────────────────────────
  # ml = {
  #   server_type = "ccx33"
  #   location    = "fsn1"
  #   replicas    = 2     # → swarm-wkr-ml-0, swarm-wkr-ml-1
  #   labels      = { "role" = "ml" }
  # }
  #
  # ─── Örnek: farklı bölgede edge node'lar ────────────
  # edge = {
  #   server_type = "cx22"
  #   location    = "nbg1"
  #   replicas    = 3     # → 3 edge worker Nürnberg'de
  #   labels      = { "role" = "edge", "zone" = "nbg" }
  # }
}

# ─── Stack Deployment ────────────────────────────────────────────────
deploy_stacks = true
# stacks listesini değiştirmek istersen variables.tf'deki default'u
# override edebilirsin. Varsayılan: 17 stack sıralı deploy.
