# ─── Hetzner Cloud ───────────────────────────────────────────────────
hcloud_token = "your-hetzner-api-token-here"

# ─── Cluster ─────────────────────────────────────────────────────────
cluster_name = "swarm"
domain       = "example.com"

# ─── SSH ─────────────────────────────────────────────────────────────
ssh_public_key_path  = "~/.ssh/id_ed25519.pub"
ssh_private_key_path = "~/.ssh/id_ed25519"

# ─── Network ─────────────────────────────────────────────────────────
network_zone   = "eu-central"
private_subnet = "10.0.0.0/24"
ip_offset      = 10  # İlk node 10.0.0.10 alır

# ─── Manager Nodes ───────────────────────────────────────────────────
managers = {
  infra = {
    server_type = "cx22"
    location    = "fsn1"
    replicas    = 1
    labels      = { "infra" = "true" }
  }
  # HA: farklı bölgede 2 manager daha
  # infra-nbg = {
  #   server_type = "cx22"
  #   location    = "nbg1"
  #   replicas    = 2
  #   labels      = { "infra" = "true", "zone" = "nbg" }
  # }
}

# ─── Worker Nodes ────────────────────────────────────────────────────
workers = {
  data = {
    server_type = "cpx31"
    location    = "fsn1"
    replicas    = 1
    labels      = { "data" = "true" }
  }
  apps = {
    server_type = "cx32"
    location    = "fsn1"
    replicas    = 1
    labels      = { "app" = "true" }
  }
  tools = {
    server_type = "cx32"
    location    = "fsn1"
    replicas    = 1
    labels      = { "tools" = "true" }
  }
}

# ─── Stack Deployment ────────────────────────────────────────────────
deploy_stacks = true

# ─── Phase 2: Lockdown ──────────────────────────────────────────────
# İlk terraform apply'da BOŞ bırak → her şey açık (setup modu)
# NetBird UI'dan setup key aldıktan sonra BURAYA YAZ:
#   netbird_setup_key = "nb-xxxxxxxxxxxx"
# Sonra: terraform apply
#
# Key burada kalıcı olduğu sürece:
#   - Sonraki tüm apply'larda yeni node'lar da otomatik lockdown olur
#   - Mevcut lockdown'lı node'lara dokunulmaz (idempotent)
#   - Hetzner Firewall kısıtlı kalır
netbird_setup_key = ""

# ─── CI Runner (opsiyonel) ──────────────────────────────────────────
# Aktif etmek için deploy_ci_runner = true yapın
# Not: apps node'una ci=true label'ı eklenmeli (workers.apps.labels'a ekle)
deploy_ci_runner   = false
# ci_runner_repo_url = "https://github.com/org/repo"
# ci_runner_pat      = "ghp_xxxxxxxxxx"
# ci_runner_replicas = 2

# ─── Offsite Backup (opsiyonel) ─────────────────────────────────────
# Hetzner Storage Box'a günlük rsync
backup_offsite_enabled = false
# backup_storage_box    = "u123456@u123456.your-storagebox.de:./backups"
