# ─── Hetzner Cloud ───────────────────────────────────────────────────
hcloud_token = "your-hetzner-api-token-here"

# ─── Cluster ─────────────────────────────────────────────────────────
cluster_name = "swarm"
domain       = "example.com"

# ─── SSH ─────────────────────────────────────────────────────────────
ssh_public_key_path  = "~/.ssh/id_ed25519.pub"
ssh_private_key_path = "~/.ssh/id_ed25519"

# ─── Network ─────────────────────────────────────────────────────────
network_zone   = "eu-central"
private_subnet = "10.0.0.0/24"
ip_offset      = 10  # İlk node 10.0.0.10 alır

# ─── Manager Nodes ───────────────────────────────────────────────────
managers = {
  infra = {
    server_type = "cx22"
    location    = "fsn1"
    replicas    = 1
    labels      = { "role" = "infra" }
  }
  # HA: farklı bölgede 2 manager daha
  # infra-nbg = {
  #   server_type = "cx22"
  #   location    = "nbg1"
  #   replicas    = 2
  #   labels      = { "role" = "infra", "zone" = "nbg" }
  # }
}

# ─── Worker Nodes ────────────────────────────────────────────────────
workers = {
  data = {
    server_type = "cpx31"
    location    = "fsn1"
    replicas    = 1
    labels      = { "role" = "data" }
  }
  apps = {
    server_type = "cx32"
    location    = "fsn1"
    replicas    = 1
    labels      = { "role" = "apps" }
  }
  tools = {
    server_type = "cx32"
    location    = "fsn1"
    replicas    = 1
    labels      = { "role" = "tools" }
  }
}

# ─── Stack Deployment ────────────────────────────────────────────────
deploy_stacks = true

# ─── Phase 2: Lockdown ──────────────────────────────────────────────
# İlk terraform apply'da BOŞ bırak → her şey açık (setup modu)
# NetBird UI'dan setup key aldıktan sonra:
#   terraform apply -var='netbird_setup_key=nb-xxxxxxxxxxxx'
# Bu komut:
#   - Tüm node'lara NetBird kurar
#   - UFW firewall'ı aktif eder (VPN subnet dahil)
#   - Hetzner Firewall'ı kısıtlar (sadece SSH, HTTP/S, WireGuard)
netbird_setup_key = ""
