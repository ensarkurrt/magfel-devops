# NetBird Dashboard Environment
# Docs: https://docs.netbird.io/selfhosted/configuration-files
# Template: "example.com" is replaced with cfg.Domains.Base at deploy time

NETBIRD_MGMT_API_ENDPOINT=https://netbird.example.com
NETBIRD_MGMT_GRPC_API_ENDPOINT=https://netbird.example.com

AUTH_AUDIENCE=netbird-dashboard
AUTH_CLIENT_ID=netbird-dashboard
AUTH_AUTHORITY=https://netbird.example.com/oauth2
AUTH_SUPPORTED_SCOPES=openid profile email
AUTH_REDIRECT_URI=https://netbird.example.com/nb-auth
AUTH_SILENT_REDIRECT_URI=https://netbird.example.com/nb-silent-auth

# TLS terminated by Traefik — no Let's Encrypt in container
LETSENCRYPT_DOMAIN=none
